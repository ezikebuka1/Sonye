# Environment template. Copy to .env.local and fill in real values there.
# .env.local is gitignored — NEVER commit real keys or secrets.

# ── Supabase (local dev: values emitted by `supabase status`) ──
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Public anon key — paste your local/cloud anon key. Set locally.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never exposed client-side. Used by server routes +
# attendance/OG routes. Set locally; never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=

# Cloud service-role key for verify scripts. Set locally; never commit.
SUPABASE_SECRET_KEY=

# ── D11 attendance / peer-report ──
# Support line the lobby + attendance pages text for no-show reports.
# Placeholder below; Ebuka sets the real number in .env.local + Vercel.
NEXT_PUBLIC_SUPPORT_PHONE=+15555550000
